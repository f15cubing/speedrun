# Anki forks are tracked as git submodules pinned to a tagged release commit.
# See docs/codebase/architecture.md and README.md.
#
# All three point at our forks (f15cubing/*) so our changes (PRD §5, mastery
# query) are pushable; each only advances by intentional bumps.
# `Anki-Android-Backend` (rsdroid) itself vendors `anki` as a nested submodule,
# so always init recursively (`git submodule update --init --recursive`).
# `ignore = dirty` keeps locally-built artifacts (and rsdroid's dirty nested
# `anki`) from showing as gitlink changes in `git status`.

[submodule "anki"]
	path = anki
	url = https://github.com/f15cubing/anki.git
	ignore = dirty

[submodule "Anki-Android"]
	path = Anki-Android
	url = https://github.com/f15cubing/Anki-Android.git
	ignore = dirty
[submodule "Anki-Android-Backend"]
	path = Anki-Android-Backend
	url = https://github.com/f15cubing/Anki-Android-Backend.git
	ignore = dirty
