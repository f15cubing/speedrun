# Anki forks are tracked as git submodules pinned to a tagged release commit.
# See docs/codebase/architecture.md and README.md.
#
# `anki` points at our fork (f15cubing/anki) so the engine change (PRD §5,
# mastery query) is pushable; it stays pinned at the upstream release commit we
# verified against (25.09.x, d52ca66) and only advances by intentional bumps.
# `Anki-Android` still points at UPSTREAM (read-only); fork it the same way when
# we begin modifying it.
#
# LATER (rsdroid): add ankidroid/Anki-Android-Backend the same way:
#   git submodule add https://github.com/ankidroid/Anki-Android-Backend.git Anki-Android-Backend
# It itself vendors `anki` as a nested submodule, so always init recursively.

[submodule "anki"]
	path = anki
	url = https://github.com/f15cubing/anki.git
	ignore = dirty

[submodule "Anki-Android"]
	path = Anki-Android
	url = https://github.com/ankidroid/Anki-Android.git
	ignore = dirty
