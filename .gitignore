# --- OS / editor junk ---
.DS_Store
**/.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- Local toolchain downloads & scratch (machine-specific, large) ---
.dl/
*.log

# --- Machine-specific environment (paths differ per developer) ---
# See README "Local setup"; copy to .androidenv and edit paths locally.
.androidenv

# --- Python sidecars / scoring models (added later) ---
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*
!.env.example

# --- Node (any root-level tooling; the forks manage their own) ---
node_modules/

# --- Secrets / access-controlled material (NEVER commit) ---
# AI gold-set, eval item bank, and any ETS-derived material must stay out of
# this repo (see docs/PRD.md §9/§12 — leakage isolation). Keep them in an
# access-controlled store.
secrets/
gold-set/
eval-bank/
# AI gold-set held-out Q&A keys + their source PDFs (see eval/goldset/README.md).
# Only the schema/README/canary-manifest/validator/module-doc are committed.
eval/goldset/data/
*.key
*.pem
*.token
.gh_token
.githubtoken

# NOTE: anki/ and Anki-Android/ are git submodules — their build outputs
# (out/, node_modules, .gradle, etc.) are governed by their own repos, not here.

# --- Study-deck pipeline build artifacts ---
# The built .apkg is a regenerated artifact; the source of truth is the generator
# + pipeline/conceptual_cards.yaml. Regenerate: python pipeline/build_deck.py --seed 42
# (.venv/ is already ignored above under the Python sidecars section.)
pipeline/dist/

# AI card pipeline + gold-set gate reports — regenerated artifacts (make ai-gate).
# The numbers are locked by tests (pipeline/aicards/tests) + documented in
# pipeline/aicards/aicards.md; the report itself is reproducible, not committed.
pipeline/aicards/out/

# W4 sync foundation — local server data + creds (never commit)
sync/.sync-data/
sync/.env
docs/evidence/w4-sync/*.tmp
scoring/out/
